<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhb.mapper.PaperInfoMapper">

    <resultMap id="BaseResultMap" type="com.lhb.entity.PaperInfo">
        <id column="id" property="id"/>
        <result column="paper_no" property="paperNo"/>
        <result column="paper_name" property="paperName"/>
        <result column="user_id" property="userId"/>
        <result column="subject_id" property="subjectId"/>
        <result column="stage_code" property="stageCode"/>
        <result column="grade_code" property="gradeCode"/>
        <result column="total_score" property="totalScore"/>
        <result column="question_count" property="questionCount"/>
        <result column="paper_type" property="paperType"/>
        <result column="difficulty_ratio" property="difficultyRatio"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, paper_no, paper_name, user_id, subject_id, stage_code, grade_code, total_score,
        question_count, paper_type, difficulty_ratio, status, create_time, update_time, "version"
