<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhb.mapper.AiChatConversationMapper">

    <resultMap id="BaseResultMap" type="com.lhb.entity.AiChatConversation">
        <id column="id" property="id"/>
        <result column="conversation_id" property="conversationId"/>
        <result column="user_id" property="userId"/>
        <result column="conversation_name" property="conversationName"/>
        <result column="chat_type" property="chatType"/>
        <result column="last_msg_time" property="lastMsgTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="version" property="version"/>
        <result column="conversation_value" property="conversationValue"/>
        <result column="importance" property="importance"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, conversation_id, user_id, conversation_name, chat_type, last_msg_time, status,
        create_time, update_time, "version", conversation_value, importance
    </sql>
</mapper>
