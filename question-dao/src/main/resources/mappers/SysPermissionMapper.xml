<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhb.mapper.SysPermissionMapper">

    <resultMap id="BaseResultMap" type="com.lhb.entity.SysPermission">
        <id column="id" property="id"/>
        <result column="perm_code" property="permCode"/>
        <result column="perm_name" property="permName"/>
        <result column="perm_type" property="permType"/>
        <result column="parent_perm_id" property="parentPermId"/>
