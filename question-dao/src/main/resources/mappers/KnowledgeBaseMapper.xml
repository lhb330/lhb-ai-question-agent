<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhb.mapper.KnowledgeBaseMapper">

    <resultMap id="BaseResultMap" type="com.lhb.entity.KnowledgeBase">
        <id column="id" property="id"/>
        <result column="kb_name" property="kbName"/>
        <result column="kb_type" property="kbType"/>
        <result column="subject_id" property="subjectId"/>
        <result column="stage_code" property="stageCode"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="content" property="content"/>
        <result column="embedding" property="embedding" typeHandler="com.lhb.typeHandlers.FloatArrayToVectorTypeHandler"/>
        <result column="creator_id" property="creatorId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="version" property="version"/>
        <result column="metadata" property="metadata" typeHandler="com.lhb.typeHandlers.MapToJsonTypeHandler"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, kb_name, kb_type, subject_id, stage_code, file_name, file_path, file_size, "content",
        embedding, creator_id, status, create_time, update_time, "version", metadata
    </sql>
</mapper>
